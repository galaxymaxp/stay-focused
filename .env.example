# Hosted Supabase project URL from Project Settings > API.
# Do not use a local CLI URL such as http://127.0.0.1:54321.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Hosted Supabase anon key from Project Settings > API.
# This repo uses NEXT_PUBLIC_SUPABASE_ANON_KEY and does not read NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-hosted-supabase-anon-key

# Supabase service role key (server-only). Required for background job processing and cron tasks.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_DO_NOW_MODEL=gpt-5-mini

# Scanned-PDF OCR is disabled by default to avoid using OpenAI vision as an automatic OCR engine.
# Use google_vision for rendered-page OCR, or google_document_ai for a Document AI OCR processor.
OCR_PROVIDER=disabled
OCR_MAX_PAGES_PER_JOB=24
OPENAI_OCR_AUTO_RUN=false
OPENAI_OCR_MAX_PAGES=5
OCR_MAX_JOBS_PER_SYNC=1
OCR_MAX_RETRIES_PER_RESOURCE=1

# Google Vision accepts either split service-account env vars, service-account JSON, a local
# GOOGLE_APPLICATION_CREDENTIALS path, or an API key. Split env vars are preferred on Vercel.
GOOGLE_CLOUD_PROJECT=
GOOGLE_VISION_CLIENT_EMAIL=
GOOGLE_VISION_PRIVATE_KEY=
GOOGLE_VISION_CREDENTIALS_JSON=
GOOGLE_VISION_API_KEY=
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"client_email":"...","private_key":"..."}

# Google Document AI requires a processor and OAuth-capable service account credentials.
GOOGLE_DOCUMENT_AI_PROCESSOR_NAME=projects/your-project/locations/us/processors/your-processor
# Alternatively set GOOGLE_CLOUD_PROJECT, GOOGLE_DOCUMENT_AI_LOCATION, and GOOGLE_DOCUMENT_AI_PROCESSOR_ID.

CANVAS_API_URL=https://your-school.instructure.com
CANVAS_API_TOKEN=your_canvas_access_token_here

# Public app URL (no trailing slash). Required on Vercel if you use a custom domain so that
# background queue jobs can self-call /api/do-now. Falls back to VERCEL_URL on Vercel deployments.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Secret used to authenticate calls to /api/cron/*. Set the same value in Vercel env vars.
# Without this the stuck-job cleanup cron will always return 401 and never run.
CRON_SECRET=your-random-secret-here
